    "Tippe ein Mitglied an, um es zu bearbeiten. Die Familie gilt in allen Pilot-Apps.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippe ein Mitglied an, um es zu bearbeiten. Die Familie gilt in allen Pilot-Apps."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap a member to edit. The family applies across all Pilot apps."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca un miembro para editarlo. La familia se aplica en todas las apps Pilot."
          }
        }
      }
    },
    "Wähle, welches Familienmitglied Du auf diesem Gerät bist — so siehst Du genau die für Dich freigegebenen Inhalte.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle, welches Familienmitglied Du auf diesem Gerät bist — so siehst Du genau die für Dich freigegebenen Inhalte."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose which family member you are on this device — so you see exactly the content shared with you."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige qué miembro de la familia eres en este dispositivo, así verás exactamente el contenido compartido contigo."
          }
        }
      }
    },
