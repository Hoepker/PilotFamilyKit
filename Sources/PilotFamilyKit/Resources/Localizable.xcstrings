    "Lade Mitglieder per iCloud ein oder nimm eine Einladung an — eine Familie für die ganze Suite.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lade Mitglieder per iCloud ein oder nimm eine Einladung an — eine Familie für die ganze Suite."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invite members via iCloud or accept an invitation — one family for the whole suite."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Invita a miembros por iCloud o acepta una invitación: una familia para toda la suite."
          }
        }
      }
    },
